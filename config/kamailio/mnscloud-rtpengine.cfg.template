loadmodule "rtpengine.so"

modparam("rtpengine", "rtpengine_sock", "{{RTPENGINE_SOCKET}}")

route[MNSCLOUD_RTPENGINE_OFFER] {
    if (has_body("application/sdp")) {
        rtpengine_offer("replace-origin replace-session-connection ICE=force DTLS=passive");
    }
}

route[MNSCLOUD_RTPENGINE_ANSWER] {
    if (has_body("application/sdp")) {
        rtpengine_answer("replace-origin replace-session-connection ICE=force");
    }
}
